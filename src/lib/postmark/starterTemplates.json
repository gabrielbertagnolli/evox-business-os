[
  {
    "alias": "starter-layout",
    "name": "Starter Layout",
    "template_type": "Layout",
    "html_body": "<!DOCTYPE html>\n<html lang=\"en\">\n  <body style=\"margin:0;padding:0;background:#f4f1ea;color:#1f2933;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f1ea;padding:24px 0;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:640px;background:#fffaf2;border:1px solid #eadfce;border-radius:20px;overflow:hidden;\">\n            <tr>\n              <td style=\"padding:32px 40px 16px;font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:#9a6b39;\">\n                {{product_name}}\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:0 40px 40px;line-height:1.6;\">\n                {{{@content}}}\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:0 40px 32px;font-size:13px;color:#52606d;line-height:1.6;\">\n                Questions? Reply to this email or reach us at {{support_email}}.\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>",
    "text_body": "{{{@content}}}\n\nQuestions? Reply to this email or reach us at {{support_email}}."
  },
  {
    "alias": "welcome-email",
    "name": "Welcome Email",
    "template_type": "Standard",
    "subject": "Welcome to {{product_name}}",
    "layout_template": "starter-layout",
    "html_body": "<h1 style=\"margin:0 0 16px;font-size:28px;line-height:1.2;\">Welcome, {{first_name}}.</h1>\n<p style=\"margin:0 0 16px;\">Your account is live and your workspace is ready.</p>\n<p style=\"margin:0 0 24px;\">Start here: {{next_step}}</p>\n<p style=\"margin:0;\">\n  <a href=\"{{cta_url}}\" style=\"display:inline-block;padding:12px 20px;border-radius:999px;background:#9a6b39;color:#fffaf2;text-decoration:none;font-weight:600;\">\n    {{cta_label}}\n  </a>\n</p>",
    "text_body": "Welcome, {{first_name}}.\n\nYour account is live and your workspace is ready.\nStart here: {{next_step}}\n\n{{cta_label}}: {{cta_url}}"
  },
  {
    "alias": "broadcast-update",
    "name": "Broadcast Update",
    "template_type": "Standard",
    "subject": "{{product_name}} update: {{headline}}",
    "layout_template": "starter-layout",
    "html_body": "<h1 style=\"margin:0 0 16px;font-size:28px;line-height:1.2;\">{{headline}}</h1>\n<p style=\"margin:0 0 16px;\">{{summary}}</p>\n<p style=\"margin:0 0 24px;\">\n  <a href=\"{{cta_url}}\" style=\"display:inline-block;padding:12px 20px;border-radius:999px;background:#1f2933;color:#fffaf2;text-decoration:none;font-weight:600;\">\n    {{cta_label}}\n  </a>\n</p>\n<p style=\"margin:0;font-size:13px;color:#52606d;\">\n  <a href=\"{{unsubscribe_url}}\" style=\"color:#52606d;\">Unsubscribe</a>\n</p>",
    "text_body": "{{headline}}\n\n{{summary}}\n\n{{cta_label}}: {{cta_url}}\n\nUnsubscribe: {{unsubscribe_url}}"
  }
]
