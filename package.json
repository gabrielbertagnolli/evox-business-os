{
  "name": "managed-product-starter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint-no-browser-localhost.mjs && eslint .",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc --noEmit",
    "verify:next-entrypoints": "node scripts/verify-next-entrypoints.mjs",
    "prepare": "husky",
    "security:audit": "bun audit --audit-level=high",
    "squawk": "docker run --rm --platform linux/amd64 -v \"$PWD:/data\" -w /data ghcr.io/sbdchd/squawk:2.55.0",
    "migration:idempotency": "bun scripts/lint-supabase-migration-idempotency.mjs"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.6",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.1",
    "@tanstack/react-query": "5.100.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "lucide-react": "1.11.0",
    "next": "16.2.6",
    "postmark": "4.0.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "stripe": "22.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "husky": "9.1.7",
    "postcss": "8.5.14",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "overrides": {
    "axios": "1.15.2",
    "postcss": "8.5.14"
  }
}
